<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.smartlock">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartLock">

        <!-- Splash Activity (Khởi chạy đầu tiên) -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SmartLock">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Đăng nhập / Đăng ký -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <!-- Quản lý thiết bị -->
        <activity
            android:name=".DeviceListActivity"
            android:exported="false" />
        <activity
            android:name=".AddDeviceActivity"
            android:exported="false" />
        <activity
            android:name=".DevicePinActivity"
            android:exported="false" />

        <!-- Main Activity (Chọn phương thức xác thực) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Face Unlock Activity -->
        <activity
            android:name=".FaceUnlockActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Home Activity (Điều khiển khóa) -->
        <activity
            android:name=".HomeActivity"
            android:exported="false" />

        <!-- Cài đặt -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- Quản lý người dùng -->
        <activity
            android:name=".activities.UserListActivity"
            android:exported="false" />

    </application>

</manifest>