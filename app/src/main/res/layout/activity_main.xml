<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_gradient_white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SMART LOCK"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn phương thức xác thực"
        android:textColor="@color/light_cyan"
        android:textSize="16sp"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btn_fingerprint"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/button_blue"
        android:text="VÂN TAY"
        android:textColor="@color/blue"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@null"/>


    <Button
        android:id="@+id/btn_face"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="NHẬN DIỆN KHUÔN MẶT"
        android:background="@drawable/button_blue"
        android:textColor="@color/blue"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:backgroundTint="@null"/>

    <Button
        android:id="@+id/btn_pin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="MÃ PIN"
        android:background="@drawable/button_blue"
        android:textColor="@color/blue"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@null"/>

</LinearLayout>